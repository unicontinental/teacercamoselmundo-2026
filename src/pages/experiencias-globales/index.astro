    <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center md:items-start justify-center gap-4 px-4 py-16">
        <div x-data="videoModal('YarhnZS9lPk')" class="w-full max-w-87.5">
            <button
                type="button"
                class="group relative block w-full aspect-350/438 cursor-pointer overflow-hidden rounded-lg text-left"
                @click="open()"
                aria-haspopup="dialog"
            >
                <Image
                    src={milagros}
                    alt="Tips para mejorar tu CV"
                    width={350}
                    height={438}
                    class="absolute inset-0 h-full w-full object-cover"
                />
                <div class="absolute inset-x-0 bottom-0 top-[48%] bg-gradient-to-t from-black via-black/80 to-transparent"></div>
                <div class="absolute inset-x-0 top-[60%] px-5 text-white">
                    <span class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-purpura transition-transform duration-300 group-hover:scale-110">
                        <svg class="ml-0.5 h-4 w-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                    </span>
                    <h3 class="mb-1 text-lg font-bold">Tips para mejorar tu CV</h3>
                    <p class="text-sm leading-snug">Descubre 3 consejos clave para transformar tu CV en una herramienta más atractiva y alineada a oportunidades internacionales.</p>
                </div>
            </button>
            <div
                x-show="isOpen"
                x-cloak
                x-transition:enter="transition ease-out duration-200"
                x-transition:enter-start="opacity-0"
                x-transition:enter-end="opacity-100"
                x-transition:leave="transition ease-in duration-150"
                x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0"
                class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 px-4"
                role="dialog"
                aria-modal="true"
                @click.self="close()"
                @keydown.escape.window="close()"
            >
                <div class="relative w-full max-w-4xl">
                    <button
                        type="button"
                        class="absolute -top-10 right-0 text-white cursor-pointer"
                        @click="close()"
                        aria-label="Cerrar video"
                    >
                        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6l-12 12" />
                        </svg>
                    </button>
                    <div class="aspect-video w-full overflow-hidden bg-black">
                        <iframe
                            x-ref="iframe"
                            title="Tips para mejorar tu CV"
                            class="h-full w-full"
                            src=""
                            allow="autoplay; fullscreen; picture-in-picture"
                            allowfullscreen
                        ></iframe>
                    </div>
                </div>
            </div>
        </div>
        <div x-data="videoModal('5UhdMxN5qDE')" class="w-full max-w-87.5">
            <button
                type="button"
                class="group relative block w-full aspect-350/438 cursor-pointer overflow-hidden rounded-lg text-left"
                @click="open()"
                aria-haspopup="dialog"
            >
                <Image
                    src={linkedin}
                    alt="¿Cómo armar un LinkedIn atractivo?"
                    width={350}
                    height={438}
                    class="absolute inset-0 h-full w-full object-cover"
                />
                <div class="absolute inset-x-0 bottom-0 top-[48%] bg-gradient-to-t from-black via-black/80 to-transparent"></div>
                <div class="absolute inset-x-0 top-[60%] px-5 text-white">
                    <span class="mb-4 flex h-10 w-10 items-center justify-center rounded-full bg-purpura transition-transform duration-300 group-hover:scale-110">
                        <svg class="ml-0.5 h-4 w-4 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                    </span>
                    <h3 class="mb-1 text-lg font-bold">¿Cómo armar un LinkedIn atractivo?</h3>
                    <p class="text-sm leading-snug">Aprende los tips básicos para construir un perfil de LinkedIn más profesional y atractivo.</p>
                </div>
            </button>
            <div
                x-show="isOpen"
                x-cloak
                x-transition:enter="transition ease-out duration-200"
                x-transition:enter-start="opacity-0"
                x-transition:enter-end="opacity-100"
                x-transition:leave="transition ease-in duration-150"
                x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0"
                class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 px-4"
                role="dialog"
                aria-modal="true"
                @click.self="close()"
                @keydown.escape.window="close()"
            >
                <div class="relative w-full max-w-4xl">
                    <button
                        type="button"
                        class="absolute -top-10 right-0 text-white cursor-pointer"
                        @click="close()"
                        aria-label="Cerrar video"
                    >
                        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6l-12 12" />
                        </svg>
                    </button>
                    <div class="aspect-video w-full overflow-hidden bg-black">
                        <iframe
                            x-ref="iframe"
                            title="¿Cómo armar un LinkedIn atractivo?"
                            class="h-full w-full"
                            src=""
                            allow="autoplay; fullscreen; picture-in-picture"
                            allowfullscreen
                        ></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>
