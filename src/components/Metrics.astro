---
import { Icon } from "astro-icon/components";
import ArrowIcon from "./ui/arrowicon.astro";

interface MetricItem {
    value: string;
    description: string;
    icon: string;
}

const { items = [] } = Astro.props as { items?: MetricItem[] };
---

<section>
    <div
        class="max-w-7xl mx-auto px-4 md:px-5 pb-16 pt-8 md:pb-24 md:pt-12 relative"
        x-data="{
            prev: null,
            next: null,
            animated: new WeakSet(),
            update() {
                const el = this.$refs.metricsTrack;
                if (!el) return;
                const max = el.scrollWidth - el.clientWidth;
                const current = el.scrollLeft;
                this.prev = current > 0 ? Math.max(0, current - el.clientWidth) : null;
                this.next = current < max ? Math.min(max, current + el.clientWidth) : null;
            },
            scrollTo(pos) {
                const el = this.$refs.metricsTrack;
                if (!el || pos === null) return;
                el.scrollTo({ left: pos, behavior: 'smooth' });
            },
            animateMetric(el) {
                if (!el || this.animated.has(el)) return;
                const raw = (el.getAttribute('data-value') || '').trim();
                if (!raw) return;
                const match = raw.match(/^([^0-9]*)([0-9][0-9.,]*)(.*)$/);
                if (!match) return;
                const prefix = match[1] || '';
                const numStr = match[2] || '';
                const suffix = match[3] || '';
                const clean = numStr.replace(/,/g, '');
                const target = Number(clean);
                if (!Number.isFinite(target)) return;
                const decimals = (clean.split('.')[1] || '').length;
                const format = (value) => {
                    const fixed = decimals ? value.toFixed(decimals) : Math.round(value).toString();
                    return `${prefix}${fixed}${suffix}`;
                };
                const startAnim = () => {
                    if (this.animated.has(el)) return;
                    this.animated.add(el);
                    const duration = 1200;
                    const start = performance.now();
                    const tick = (now) => {
                        const progress = Math.min((now - start) / duration, 1);
                        const value = target * progress;
                        el.textContent = format(value);
                        if (progress < 1) {
                            requestAnimationFrame(tick);
                        } else {
                            el.textContent = raw;
                        }
                    };
                    requestAnimationFrame(tick);
                };
                el.textContent = format(0);
                if ('IntersectionObserver' in window) {
                    const observer = new IntersectionObserver((entries) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                observer.disconnect();
                                startAnim();
                            }
                        });
                    }, { threshold: 0.4 });
                    observer.observe(el);
                } else {
                    startAnim();
                }
            }
        }"
        x-init="$nextTick(() => update())"
    >
        <div
            class="flex md:grid md:grid-cols-4 gap-4 overflow-x-auto md:overflow-visible snap-x snap-mandatory md:snap-none"
            x-ref="metricsTrack"
            @scroll.debounce.50ms="update()"
        >
            {items.map((item) => (
                <article class="flex-none w-full md:w-auto snap-start px-6 py-8 text-center gap-8">
                    <Icon
                        name={item.icon}
                        class="mx-auto mb-4 h-10 w-10 text-black md:h-18.75 md:w-18.75"
                        aria-hidden="true"
                    />
                    <p
                        class="font-wideBold text-3xl md:text-6xl text-black"
                        data-value={item.value}
                        x-init="animateMetric($el)"
                    >
                        {item.value}
                    </p>
                    <p class="mt-4 text-sm text-gray-600 md:text-base">{item.description}</p>
                </article>
            ))}
        </div>
        <div
            class="col-span-5 flex justify-center gap-2 px-4 mt-2"
            class:list={{ 'md:hidden': items.length > 1 }}
        >
            <button
                type="button"
                class="flex rounded-full items-center justify-center p-2 transition"
                aria-label="previous slide"
                @click="scrollTo(prev)"
                :class="[prev != null ? 'text-black cursor-pointer' : 'text-black/50']"
            >
                <ArrowIcon />
            </button>
            <button
                type="button"
                class="flex rounded-full items-center justify-center p-2 transition"
                aria-label="next slide"
                @click="scrollTo(next)"
                :class="[next != null ? 'text-black cursor-pointer' : 'text-black/50']"
            >
                <ArrowIcon rotate />
            </button>
        </div>
    </div>
</section>
