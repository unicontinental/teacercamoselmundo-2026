---
import { Icon } from "astro-icon/components";
import ArrowIcon from "./ui/arrowicon.astro";

interface MetricItem {
    value: string;
    description: string;
    icon: string;
}

const { items = [] } = Astro.props as { items?: MetricItem[] };
---

<section>
    <div
        class="max-w-7xl mx-auto px-4 md:px-5 py-16 md:py-24 relative"
        x-data="{
            prev: null,
            next: null,
            update() {
                const el = this.$refs.metricsTrack;
                if (!el) return;
                const max = el.scrollWidth - el.clientWidth;
                const current = el.scrollLeft;
                this.prev = current > 0 ? Math.max(0, current - el.clientWidth) : null;
                this.next = current < max ? Math.min(max, current + el.clientWidth) : null;
            },
            scrollTo(pos) {
                const el = this.$refs.metricsTrack;
                if (!el || pos === null) return;
                el.scrollTo({ left: pos, behavior: 'smooth' });
            }
        }"
        x-init="$nextTick(() => update())"
    >
        <div
            class="flex md:grid md:grid-cols-4 gap-4 overflow-x-auto md:overflow-visible snap-x snap-mandatory md:snap-none"
            x-ref="metricsTrack"
            @scroll.debounce.50ms="update()"
        >
            {items.map((item) => (
                <article class="flex-none w-full md:w-auto snap-start px-6 py-8 text-center gap-8">
                    <Icon
                        name={item.icon}
                        class="mx-auto mb-4 h-10 w-10 text-black md:h-18.75 md:w-18.75"
                        aria-hidden="true"
                    />
                    <p class="font-wideBold text-3xl md:text-6xl text-black">{item.value}</p>
                    <p class="mt-4 text-sm text-gray-600 md:text-base">{item.description}</p>
                </article>
            ))}
        </div>
        <div
            class="col-span-5 flex justify-center gap-2 px-4 mt-2"
            class:list={{ 'md:hidden': items.length > 1 }}
        >
            <button
                type="button"
                class="flex rounded-full items-center justify-center p-2 transition"
                aria-label="previous slide"
                @click="scrollTo(prev)"
                :class="[prev != null ? 'text-black cursor-pointer' : 'text-black/50']"
            >
                <ArrowIcon />
            </button>
            <button
                type="button"
                class="flex rounded-full items-center justify-center p-2 transition"
                aria-label="next slide"
                @click="scrollTo(next)"
                :class="[next != null ? 'text-black cursor-pointer' : 'text-black/50']"
            >
                <ArrowIcon rotate />
            </button>
        </div>
    </div>
</section>
