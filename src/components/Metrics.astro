---
interface MetricItem {
    value: string;
    description: string;
}

const { items = [] } = Astro.props as { items?: MetricItem[] };
---

<section>
    <div class="max-w-7xl mx-auto px-4 md:px-5 py-16 md:py-24">
        <div class="flex md:grid md:grid-cols-4 gap-4 overflow-x-auto md:overflow-visible snap-x snap-mandatory md:snap-none">
            {items.map((item) => (
                <article class="flex-none w-5/6 md:w-auto snap-start px-6 py-8 text-center gap-8">
                    <p class="font-wideBold text-3xl md:text-6xl text-gray-900">{item.value}</p>
                    <p class="mt-4 text-sm text-gray-600 md:text-base">{item.description}</p>
                </article>
            ))}
        </div>
    </div>
</section>
