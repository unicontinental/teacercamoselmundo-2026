---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

const { image, alt, title, videoId = "dQw4w9WgXcQ" } = Astro.props;
---

<section>
    <div class="max-w-7xl mx-auto px-4 md:px-5 py-10 md:py-16">
        <div class="relative overflow-hidden rounded-xl" x-data="videoModal()" x-init={`videoId = \"${videoId}\"`}>
            <Image
                src={image}
                alt={alt}
                width={1460}
                height={640}
                class="w-full h-[220px] md:h-[420px] object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/40 to-transparent">
                <div class="absolute inset-0 flex items-end">
                    <div class="p-6 md:p-10 max-w-7xl">
                        <button
                            type="button"
                            class="mb-4 inline-flex items-center gap-4 text-white"
                            @click="open()"
                            aria-haspopup="dialog"
                            aria-label="Reproducir video"
                        >
                            <span class="flex md:h-[69px] md:w-[69px] h-[40px] w-[40px] items-center justify-center rounded-full bg-purpura">
                                <Icon name="play" class="h-10 w-10 text-white" />
                            </span>
                            <span class="text-xs text-left md:text-2xl font-wideBold uppercase leading-tight max-w-2xl">
                                {title}
                            </span>
                        </button>
                    </div>
                </div>
            </div>
            <div
                x-show="isOpen"
                x-cloak
                x-transition:enter="transition ease-out duration-200"
                x-transition:enter-start="opacity-0"
                x-transition:enter-end="opacity-100"
                x-transition:leave="transition ease-in duration-150"
                x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0"
                class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 px-4"
                role="dialog"
                aria-modal="true"
                @click.self="close()"
                @keydown.escape.window="close()"
            >
                <div class="relative w-full max-w-4xl">
                    <button
                        type="button"
                        class="absolute -top-10 right-0 text-white cursor-pointer"
                        @click="close()"
                        aria-label="Cerrar video"
                    >
                        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6l-12 12" />
                        </svg>
                    </button>
                    <div class="aspect-video w-full overflow-hidden bg-black">
                        <iframe
                            x-ref="iframe"
                            title="Video"
                            class="h-full w-full"
                            src=""
                            allow="autoplay; fullscreen; picture-in-picture"
                            allowfullscreen
                        ></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
