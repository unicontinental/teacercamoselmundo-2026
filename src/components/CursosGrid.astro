---
const { items = [], categories = [] } = Astro.props;
const itemsJson = JSON.stringify(items);
const categoriesJson = JSON.stringify(categories);
---

<section class="bg-white">
    <div
        class="max-w-7xl mx-auto px-4 md:px-5 py-12 md:py-16"
        x-data={`{
            items: ${itemsJson},
            categories: ${categoriesJson},
            search: '',
            selectedCategory: '',
            view: 'grid',
            showCategoryMenu: false,
            get filtered() {
                const q = this.search.toLowerCase().trim();
                return this.items.filter((item) => {
                    const matchesSearch = !q || item.title.toLowerCase().includes(q) || (item.description || '').toLowerCase().includes(q);
                    const matchesCategory = !this.selectedCategory || item.category === this.selectedCategory;
                    return matchesSearch && matchesCategory;
                });
            },
        }`}
    >
        <p class="text-center text-base md:text-lg max-w-3xl mx-auto mb-10 md:mb-12 leading-relaxed">
            Accede gratuitamente a <strong>cursos sobre tendencias actuale</strong>s y desarrolla habilidades para fortalecer tu perfil profesional y futuro laboral.
        </p>

        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
            <div class="flex items-center gap-4 flex-wrap">
                <span class="text-sm whitespace-nowrap" x-text="'Total cursos (' + filtered.length + ')'"></span>
                <div class="relative">
                    <input
                        type="text"
                        placeholder="Buscas cursos"
                        x-model="search"
                        class="border border-gray-300 rounded-full pl-4 pr-10 py-2 text-sm w-full md:w-56 focus:outline-none focus:ring-2 focus:ring-purpura/50"
                        aria-label="Buscar cursos"
                    />
                    <svg class="absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-500 pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="7"></circle>
                        <path stroke-linecap="round" d="m21 21-4.3-4.3"></path>
                    </svg>
                </div>
            </div>

            <div class="flex items-center gap-3 flex-wrap">
                <template x-if="selectedCategory">
                    <button
                        type="button"
                        @click="selectedCategory = ''"
                        class="bg-purpura text-white text-sm rounded-full pl-3 pr-2 py-1 flex items-center gap-2 cursor-pointer hover:bg-purpura/90 transition-colors"
                        aria-label="Quitar filtro de categoría"
                    >
                        <span x-text="selectedCategory"></span>
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M6 6l12 12M18 6l-12 12" /></svg>
                    </button>
                </template>

                <div class="relative" @click.away="showCategoryMenu = false">
                    <button
                        type="button"
                        @click="showCategoryMenu = !showCategoryMenu"
                        class="text-sm flex items-center gap-1 cursor-pointer hover:text-purpura transition-colors"
                        aria-haspopup="listbox"
                        :aria-expanded="showCategoryMenu"
                    >
                        Categoría
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" :class="showCategoryMenu ? 'rotate-180' : ''"><path stroke-linecap="round" stroke-linejoin="round" d="M6 9l6 6 6-6" /></svg>
                    </button>
                    <div
                        x-show="showCategoryMenu"
                        x-cloak
                        x-transition.origin.top.right
                        class="absolute right-0 top-full mt-2 bg-white border border-gray-200 rounded-md shadow-md z-10 min-w-44 py-1"
                        role="listbox"
                    >
                        <template x-for="cat in categories" :key="cat">
                            <button
                                type="button"
                                @click="selectedCategory = cat; showCategoryMenu = false"
                                class="w-full text-left px-3 py-2 hover:bg-gray-100 text-sm cursor-pointer"
                                :class="selectedCategory === cat ? 'text-purpura font-semibold' : ''"
                                x-text="cat"
                            ></button>
                        </template>
                    </div>
                </div>

                <div class="flex items-center gap-1 border-l border-gray-300 pl-3 ml-1">
                    <button
                        type="button"
                        @click="view = 'grid'"
                        :class="view === 'grid' ? 'text-purpura' : 'text-gray-400'"
                        class="p-1 cursor-pointer hover:text-purpura transition-colors"
                        aria-label="Vista cuadrícula"
                    >
                        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M3 3h8v8H3zM13 3h8v8h-8zM3 13h8v8H3zM13 13h8v8h-8z"/></svg>
                    </button>
                    <button
                        type="button"
                        @click="view = 'list'"
                        :class="view === 'list' ? 'text-purpura' : 'text-gray-400'"
                        class="p-1 cursor-pointer hover:text-purpura transition-colors"
                        aria-label="Vista lista"
                    >
                        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M3 5h18v3H3zM3 10.5h18v3H3zM3 16h18v3H3z"/></svg>
                    </button>
                </div>
            </div>
        </div>

        <div :class="view === 'grid' ? 'grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6' : 'flex flex-col gap-4'">
            <template x-for="item in filtered" :key="item.id">
                <article
                    class="border border-gray-200 rounded-lg overflow-hidden bg-white"
                    :class="view === 'list' ? 'flex flex-col sm:flex-row' : 'flex flex-col'"
                >
                    <div class="relative" :class="view === 'list' ? 'sm:w-1/3 shrink-0' : ''">
                        <img
                            :src="item.image"
                            :alt="item.title"
                            class="w-full h-48 object-cover"
                            :class="view === 'list' ? 'sm:h-full' : ''"
                            loading="lazy"
                        />
                        <template x-if="item.badge">
                            <span class="absolute top-3 right-3 bg-purpura text-white text-xs px-2 py-1 rounded" x-text="item.badge"></span>
                        </template>
                    </div>
                    <div class="p-4 md:p-5 flex-1 flex flex-col">
                        <h3 class="font-bold text-base md:text-lg mb-2" x-text="item.title"></h3>
                        <p class="text-sm text-gray-600 mb-4 flex-1" x-text="item.description"></p>
                        <a
                            :href="item.href"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-block bg-black hover:bg-purpura text-white text-sm font-semibold px-5 py-2 rounded-full transition-colors self-start"
                        >
                            Comenzar
                        </a>
                    </div>
                </article>
            </template>

            <template x-if="filtered.length === 0">
                <p class="text-center text-gray-500 py-12" :class="view === 'grid' ? 'col-span-full' : ''">
                    No se encontraron cursos.
                </p>
            </template>
        </div>
    </div>
</section>
