---
import "../styles/tailwind.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Icon } from "astro-icon/components";
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Te Acercamos el Mundo | Intercambios y convenios internacionales</title>
    <meta
      name="description"
      content="Descubre programas y convenios académicos, intercambios internacionales y experiencias globales que fortalecen tu perfil. ¡Solicita información ahora!"
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Te Acercamos el Mundo | Intercambios y convenios internacionales" />
    <meta
      property="og:description"
      content="Descubre programas y convenios académicos, intercambios internacionales y experiencias globales que fortalecen tu perfil. ¡Solicita información ahora!"
    />
    <meta property="og:image" content="/miniatura.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Te Acercamos el Mundo | Intercambios y convenios internacionales" />
    <meta
      name="twitter:description"
      content="Descubre programas y convenios académicos, intercambios internacionales y experiencias globales que fortalecen tu perfil. ¡Solicita información ahora!"
    />
    <meta name="twitter:image" content="/miniatura.jpg" />

    <script async is:inline src={`https://www.googletagmanager.com/gtag/js?id=G-BDRRV0B80Z`}></script>
    <script is:inline define:vars={{ tagmanager: 'G-BDRRV0B80Z' }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', tagmanager);
    </script>
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <a
      href="https://wa.me/51971115546?text=%C2%A1Hola,%20en%20la%20Universidad%20Continental%20te%20acercamos%20el%20mundo!%20Conoce%20nuestras%20carreras%20y%20propuesta%20internacional.%20%3A%29"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed bottom-4 right-4 z-20 md:w-42 h-auto w-24 drop-shadow-lg"
      aria-label="WhatsApp"
    >
      <Icon name="wsp" class="h-full w-full wsp-pulse" aria-hidden="true" />
    </a>
  </body>
</html>
<style>
  .wsp-pulse {
    transform-origin: center;
    animation: wsp-pulse 2s ease-in-out infinite;
  }

  @keyframes wsp-pulse {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.08);
    }
  }
</style>
